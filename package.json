{
  "name": "portifolio-website",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.5.2",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint --max-warnings=100 \"src/**/*.{js,jsx,ts,tsx}\" \"scripts/**/*.{js,ts}\"",
    "lint:fix": "eslint --fix \"src/**/*.{js,jsx,ts,tsx}\" \"scripts/**/*.{js,ts}\"",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,md}\"",
    "test": "vitest run --config vitest.config.mjs --configLoader native",
    "test:watch": "vitest --config vitest.config.mjs --configLoader native",
    "type-check": "tsc --noEmit",
    "i18n:unused": "tsx scripts/check-i18n.ts"
  },
  "dependencies": {
    "@floating-ui/react": "^0.27.13",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-scroll-area": "^1.2.9",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tabs": "^1.1.12",
    "@radix-ui/react-tooltip": "^1.2.7",
    "@react-email/render": "^2.0.0",
    "@tailwindcss/postcss": "^4",
    "@tanstack/react-table": "^8.21.3",
    "@tsparticles/engine": "^3.9.1",
    "@tsparticles/react": "^3.0.0",
    "@tsparticles/slim": "^3.9.1",
    "@types/three": "^0.183.1",
    "@typescript-eslint/parser": "^8.34.1",
    "@vercel/kv": "^3.0.0",
    "boring-avatars": "^1.11.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "embla-carousel-autoplay": "^8.6.0",
    "embla-carousel-react": "^8.6.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-prettier": "^5.4.1",
    "framer-motion": "^12.16.0",
    "gsap": "^3.13.0",
    "lucide-react": "^0.513.0",
    "motion": "^12.38.0",
    "next": "^16.1.0",
    "next-intl": "^4.1.0",
    "ogl": "^1.0.11",
    "prettier": "^3.5.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-icons": "^5.5.0",
    "react-use-measure": "^2.1.7",
    "resend": "^6.4.2",
    "swr": "^2.3.3",
    "tailwind-merge": "^3.3.0",
    "tailwindcss": "^4",
    "tailwindcss-animate": "^1.0.7",
    "three": "^0.167.1",
    "tw-animate-css": "^1.3.4",
    "vaul": "^1.1.2",
    "zod": "^3.25.75",
    "zustand": "^5.0.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@eslint/js": "^9.28.0",
    "@next/eslint-plugin-next": "^15.3.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@typescript-eslint/eslint-plugin": "^8.33.1",
    "dotenv": "^16.5.0",
    "embla-carousel": "^8.6.0",
    "eslint": "^9",
    "eslint-config-next": "15.3.3",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-next": "^0.0.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "jsdom": "^29.0.1",
    "lint-staged": "^16.1.0",
    "tsx": "^4.20.3",
    "typescript": "^5",
    "typescript-eslint": "^8.33.1",
    "vitest": "^4.1.2"
  },
  "lint-staged": {
    "*.{js,ts,tsx}": [
      "eslint --max-warnings=0",
      "sh -c \"tsc -p tsconfig.json --noEmit\""
    ],
    "*.{md,json,yml,yaml,css,scss}": "prettier -w",
    "package.json": "prettier -w"
  }
}
