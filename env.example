# Last.fm API
# Used for: Music stats, recent tracks, top artists
LASTFM_API_KEY=your_lastfm_api_key_here
LASTFM_USERNAME=your_lastfm_username_here
LASTFM_USER_AGENT=lucashdo-portfolio/1.0 (+https://www.lucashdo.com)

# Steam API
# Used for: Gaming profile, recent games, owned games
STEAM_API_KEY=your_steam_api_key_here
STEAM_ID=your_steam_id_here

# Lyfta API
# Used for: Lyfta integration
LYFTA_API_KEY=your_lyfta_api_key_here

# Cloudflare Turnstile
# Used for: Contact form captcha/bot protection
TURNSTILE_SECRET_KEY=your_turnstile_secret_key_here
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your_turnstile_site_key_here

# Discord Webhook
# Used for: Contact form notifications
DISCORD_WEBHOOK_URL=your_discord_webhook_url_here

# Discord User ID
# Used for: Discord presence card via Lanyard API
NEXT_PUBLIC_DISCORD_ID=your_discord_user_id_here

# MyAnimeList Username
# Used for: Anime/Manga stats via Jikan API
NEXT_PUBLIC_MAL_USERNAME=your_mal_username_here
